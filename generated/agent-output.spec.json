{
  "apiName": "Book API",
  "description": "A simple CRUD API for books",
  "entities": [
    {
      "name": "book",
      "tableName": "books",
      "fields": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "unique": false
        },
        {
          "name": "author",
          "type": "string",
          "required": true,
          "unique": false
        },
        {
          "name": "publishedYear",
          "type": "number",
          "required": false,
          "unique": false
        }
      ]
    }
  ],
  "endpoints": [
    {
      "method": "GET",
      "path": "/books",
      "entity": "book",
      "operation": "list",
      "auth": false
    },
    {
      "method": "POST",
      "path": "/books",
      "entity": "book",
      "operation": "create",
      "auth": false
    },
    {
      "method": "GET",
      "path": "/books/:id",
      "entity": "book",
      "operation": "get",
      "auth": false
    },
    {
      "method": "PUT",
      "path": "/books/:id",
      "entity": "book",
      "operation": "update",
      "auth": false
    },
    {
      "method": "DELETE",
      "path": "/books/:id",
      "entity": "book",
      "operation": "delete",
      "auth": false
    }
  ],
  "auth": {
    "type": "none",
    "secretKey": ""
  },
  "validation": [],
  "framework": "nodejs",
  "database": "postgresql"
}